-- WARNING: This schema is for context only and is not meant to be run.
-- Table order and constraints may not be valid for execution.

CREATE TABLE public.bars (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  name text NOT NULL,
  owner_id uuid NOT NULL,
  invite_code text NOT NULL UNIQUE,
  created_at timestamp with time zone DEFAULT now(),
  is_public boolean NOT NULL DEFAULT false,
  CONSTRAINT bars_pkey PRIMARY KEY (id),
  CONSTRAINT bars_owner_id_fkey FOREIGN KEY (owner_id) REFERENCES auth.users(id)
);
CREATE TABLE public.cocktail_catalog (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  name text NOT NULL,
  base_spirit text,
  category text,
  glass text,
  method text,
  difficulty text,
  abv numeric,
  description text,
  recipe jsonb NOT NULL DEFAULT '[]'::jsonb,
  profile jsonb DEFAULT '[]'::jsonb,
  season jsonb DEFAULT '[]'::jsonb,
  tags jsonb DEFAULT '[]'::jsonb,
  creator text,
  image text,
  cocktail_style text,
  submitted_by_bar_id uuid,
  created_at timestamp with time zone DEFAULT now(),
  ice jsonb,
  CONSTRAINT cocktail_catalog_pkey PRIMARY KEY (id),
  CONSTRAINT cocktail_catalog_submitted_by_bar_id_fkey FOREIGN KEY (submitted_by_bar_id) REFERENCES public.bars(id)
);
CREATE TABLE public.cocktails (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  name text NOT NULL,
  base_spirit text,
  category text,
  glass text,
  method text,
  difficulty text,
  abv numeric,
  description text,
  profile jsonb DEFAULT '[]'::jsonb,
  ice jsonb DEFAULT '[]'::jsonb,
  season jsonb DEFAULT '[]'::jsonb,
  creator text,
  image text,
  tags jsonb DEFAULT '[]'::jsonb,
  recipe jsonb NOT NULL DEFAULT '[]'::jsonb,
  created_at timestamp with time zone DEFAULT now(),
  bar_id uuid,
  cocktail_style text,
  submitted_by_bar_id uuid,
  CONSTRAINT cocktails_pkey PRIMARY KEY (id),
  CONSTRAINT cocktails_bar_id_fkey FOREIGN KEY (bar_id) REFERENCES public.bars(id),
  CONSTRAINT cocktails_submitted_by_bar_id_fkey FOREIGN KEY (submitted_by_bar_id) REFERENCES public.cocktail_catalog(id)
);
CREATE TABLE public.drink_history (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  drinker_id uuid NOT NULL,
  cocktail_id uuid NOT NULL,
  bar_id uuid NOT NULL,
  ordered_at timestamp with time zone DEFAULT now(),
  CONSTRAINT drink_history_pkey PRIMARY KEY (id),
  CONSTRAINT drink_history_drinker_id_fkey FOREIGN KEY (drinker_id) REFERENCES public.drinker_profiles(id),
  CONSTRAINT drink_history_cocktail_id_fkey FOREIGN KEY (cocktail_id) REFERENCES public.cocktails(id),
  CONSTRAINT drink_history_bar_id_fkey FOREIGN KEY (bar_id) REFERENCES public.bars(id)
);
CREATE TABLE public.drinker_favorites (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  drinker_id uuid NOT NULL,
  cocktail_id uuid NOT NULL,
  bar_id uuid NOT NULL,
  created_at timestamp with time zone DEFAULT now(),
  CONSTRAINT drinker_favorites_pkey PRIMARY KEY (id),
  CONSTRAINT drinker_favorites_cocktail_id_fkey FOREIGN KEY (cocktail_id) REFERENCES public.cocktails(id),
  CONSTRAINT drinker_favorites_bar_id_fkey FOREIGN KEY (bar_id) REFERENCES public.bars(id),
  CONSTRAINT drinker_favorites_drinker_id_fkey FOREIGN KEY (drinker_id) REFERENCES public.drinker_profiles(id)
);
CREATE TABLE public.drinker_profiles (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  bar_id uuid NOT NULL,
  pseudo text NOT NULL,
  created_at timestamp with time zone DEFAULT now(),
  token uuid DEFAULT gen_random_uuid() UNIQUE,
  CONSTRAINT drinker_profiles_pkey PRIMARY KEY (id),
  CONSTRAINT drinker_profiles_bar_id_fkey FOREIGN KEY (bar_id) REFERENCES public.bars(id)
);
CREATE TABLE public.ingredients (
  id uuid NOT NULL DEFAULT uuid_generate_v4(),
  name text NOT NULL,
  type text NOT NULL,
  category text NOT NULL,
  available boolean DEFAULT false,
  created_at timestamp with time zone DEFAULT now(),
  abv real,
  family text,
  bar_id uuid,
  CONSTRAINT ingredients_pkey PRIMARY KEY (id),
  CONSTRAINT ingredients_bar_id_fkey FOREIGN KEY (bar_id) REFERENCES public.bars(id)
);
CREATE TABLE public.menu_cards (
  id uuid NOT NULL DEFAULT gen_random_uuid(),
  name text NOT NULL,
  cocktail_ids ARRAY DEFAULT '{}'::uuid[],
  created_at timestamp with time zone DEFAULT now(),
  bar_id uuid,
  CONSTRAINT menu_cards_pkey PRIMARY KEY (id),
  CONSTRAINT menu_cards_bar_id_fkey FOREIGN KEY (bar_id) REFERENCES public.bars(id)
);